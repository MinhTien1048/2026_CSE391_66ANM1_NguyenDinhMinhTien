<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header>
        <nav>
            <div class="logo">TRAVEL GOALS</div>
            <ul>
                <li><a href="#">Destinations</a></li>
                <li><a href="#">About</a></li>
            </ul>
        </nav>
        <div class="hero">
            <h1>JOE'S TRAVEL PAGE</h1>
            <p class="p1">LET'S EXPLORE THE WORLD TOGETHER</p>
            <button>Discover places</button>
        </div>
    </header>
    <main>
        <section class="highlight">
            <h2>HIGHLIGHTS</h2>
            <div class="cards">

                <div class="card">
                    <img src="miami.jpg" alt="">
                    <p>MIAMI USA</p>
                </div>
                <div class="card">
                    <img src="munich.jpg" alt="">
                    <p>MUNICH GERMANY</p>
                </div>
                <div class="card">
                    <img src="barcelona.jpg" alt="">
                    <p>BARCELONA SPAIN</p>
                </div>
            </div>
        </section>
    </main>
    <footer>
        <div class="social">
        <span>📷 Instagram</span>
        <span>📘 Facebook</span>
    </div>
    </footer>

</body>
</html>
